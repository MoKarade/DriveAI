{
  "compilerOptions": {
    "target": "ES2020",
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true,
    "skipLibCheck": true,
    "isolatedModules": true,
    "noEmit": true,
    // "node" : les fonctions serverless ../api (node:crypto, process.env) sont typées par le
    // MÊME `tsc --noEmit` que l'app — sans CI dédiée à la racine, c'est ici qu'elles se vérifient.
    "types": ["vite/client", "node"]
  },
  "include": ["src", "test", "../api"]
}
